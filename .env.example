# Schoonmaker — copy to game/.env (or ER doc/.env for legacy layout)

OPENAI_API_KEY=

# Local Llama via Ollama — fallback when OpenAI credits run out (case chat + narrative refine)
# Llama already installed — just run: ollama serve (match OLLAMA_MODEL to your installed model)
# LLM_PROVIDER=auto
# OLLAMA_MODEL=llama3.2
# OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat
# OLLAMA_ENABLED=1

# fal.ai — https://fal.ai/dashboard/keys (optional scene generation)
FAL_KEY=

# Optional: fal | openai | auto
# SCENE_IMAGE_PROVIDER=auto
# FAL_SCENE_MODEL=fal-ai/joyai-image-edit

# API port (default 3001)
# SPORTMAKER_API_PORT=3001

# Optional — Chatterbox Turbo voice clone (high-quality Read aloud)
# If unset, Read aloud falls back to the browser voice automatically.
# Install Chatterbox separately — do NOT copy the full ML repo into this project.
# CHATTERBOX_ROOT=C:\Users\steve\chatterbox
# CHATTERBOX_PYTHON=C:\Users\steve\chatterbox\.venv\Scripts\python.exe
# CHATTERBOX_VOICE_REF=C:\Users\steve\chatterbox\VoiceClone_STEF_AMP_under25MB.flac

# Optional — magic link email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
